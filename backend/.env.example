# Environment Configuration

# Database Configuration
MONGO_URI=mongodb://localhost:27017/gaming-accounts

# Server Configuration
NODE_ENV=production
PORT=5000

# Backend Base URL (for generating full image URLs)
BASE_URL=https://alphastore-ap.onrender.com

# Frontend URL (for CORS)
# For Netlify deployment:
FRONTEND_URL=https://your-site.netlify.app
# For local development:
# FRONTEND_URL=http://localhost:3000

# Static Files
PUBLIC_DIR=./public
UPLOADS_DIR=./public/uploads

# Security
JWT_SECRET=your-secret-key-here
BCRYPT_ROUNDS=12

# Google OAuth (Get from Google Cloud Console)
# IMPORTANT: This must match the redirect_uri in your frontend config
# The frontend redirects to Google, then Google redirects back to this URL
GOOGLE_REDIRECT_URI=https://silver-frangipane-2ddeca.netlify.app/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
