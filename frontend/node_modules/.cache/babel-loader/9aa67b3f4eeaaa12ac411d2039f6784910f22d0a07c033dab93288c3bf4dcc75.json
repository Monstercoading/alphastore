{"ast":null,"code":"import{useState,useCallback}from'react';import{useNavigate}from'react-router-dom';export const useNavigationWithDelay=()=>{const[isLoading,setIsLoading]=useState(false);const navigate=useNavigate();const navigateWithDelay=useCallback(function(path){let delay=arguments.length>1&&arguments[1]!==undefined?arguments[1]:2500;setIsLoading(true);setTimeout(()=>{navigate(path);setIsLoading(false);},delay);},[navigate]);const redirectWithDelay=useCallback(function(url){let delay=arguments.length>1&&arguments[1]!==undefined?arguments[1]:2500;setIsLoading(true);setTimeout(()=>{window.location.href=url;setIsLoading(false);},delay);},[]);const reloadWithDelay=useCallback(function(){let delay=arguments.length>0&&arguments[0]!==undefined?arguments[0]:2500;setIsLoading(true);setTimeout(()=>{window.location.reload();},delay);},[]);return{isLoading,navigateWithDelay,redirectWithDelay,reloadWithDelay,setIsLoading};};","map":{"version":3,"names":["useState","useCallback","useNavigate","useNavigationWithDelay","isLoading","setIsLoading","navigate","navigateWithDelay","path","delay","arguments","length","undefined","setTimeout","redirectWithDelay","url","window","location","href","reloadWithDelay","reload"],"sources":["C:/Users/Monster/CascadeProjects/gaming-accounts-marketplace/frontend/src/hooks/useNavigationWithDelay.ts"],"sourcesContent":["import { useState, useCallback } from 'react';\nimport { useNavigate } from 'react-router-dom';\n\nexport const useNavigationWithDelay = () => {\n  const [isLoading, setIsLoading] = useState(false);\n  const navigate = useNavigate();\n\n  const navigateWithDelay = useCallback((path: string, delay: number = 2500) => {\n    setIsLoading(true);\n    \n    setTimeout(() => {\n      navigate(path);\n      setIsLoading(false);\n    }, delay);\n  }, [navigate]);\n\n  const redirectWithDelay = useCallback((url: string, delay: number = 2500) => {\n    setIsLoading(true);\n    \n    setTimeout(() => {\n      window.location.href = url;\n      setIsLoading(false);\n    }, delay);\n  }, []);\n\n  const reloadWithDelay = useCallback((delay: number = 2500) => {\n    setIsLoading(true);\n    \n    setTimeout(() => {\n      window.location.reload();\n    }, delay);\n  }, []);\n\n  return {\n    isLoading,\n    navigateWithDelay,\n    redirectWithDelay,\n    reloadWithDelay,\n    setIsLoading\n  };\n};\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,WAAW,KAAQ,OAAO,CAC7C,OAASC,WAAW,KAAQ,kBAAkB,CAE9C,MAAO,MAAM,CAAAC,sBAAsB,CAAGA,CAAA,GAAM,CAC1C,KAAM,CAACC,SAAS,CAAEC,YAAY,CAAC,CAAGL,QAAQ,CAAC,KAAK,CAAC,CACjD,KAAM,CAAAM,QAAQ,CAAGJ,WAAW,CAAC,CAAC,CAE9B,KAAM,CAAAK,iBAAiB,CAAGN,WAAW,CAAC,SAACO,IAAY,CAA2B,IAAzB,CAAAC,KAAa,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,IAAI,CACvEL,YAAY,CAAC,IAAI,CAAC,CAElBQ,UAAU,CAAC,IAAM,CACfP,QAAQ,CAACE,IAAI,CAAC,CACdH,YAAY,CAAC,KAAK,CAAC,CACrB,CAAC,CAAEI,KAAK,CAAC,CACX,CAAC,CAAE,CAACH,QAAQ,CAAC,CAAC,CAEd,KAAM,CAAAQ,iBAAiB,CAAGb,WAAW,CAAC,SAACc,GAAW,CAA2B,IAAzB,CAAAN,KAAa,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,IAAI,CACtEL,YAAY,CAAC,IAAI,CAAC,CAElBQ,UAAU,CAAC,IAAM,CACfG,MAAM,CAACC,QAAQ,CAACC,IAAI,CAAGH,GAAG,CAC1BV,YAAY,CAAC,KAAK,CAAC,CACrB,CAAC,CAAEI,KAAK,CAAC,CACX,CAAC,CAAE,EAAE,CAAC,CAEN,KAAM,CAAAU,eAAe,CAAGlB,WAAW,CAAC,UAA0B,IAAzB,CAAAQ,KAAa,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,IAAI,CACvDL,YAAY,CAAC,IAAI,CAAC,CAElBQ,UAAU,CAAC,IAAM,CACfG,MAAM,CAACC,QAAQ,CAACG,MAAM,CAAC,CAAC,CAC1B,CAAC,CAAEX,KAAK,CAAC,CACX,CAAC,CAAE,EAAE,CAAC,CAEN,MAAO,CACLL,SAAS,CACTG,iBAAiB,CACjBO,iBAAiB,CACjBK,eAAe,CACfd,YACF,CAAC,CACH,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}